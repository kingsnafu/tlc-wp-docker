# Site
SITE_SLUG=clientname
SITE_URL=http://localhost

# PHP / MariaDB versions
PHP_VERSION=8.3
MARIADB_VERSION=11.4

# Ports (change if running multiple sites simultaneously)
HTTP_PORT=80
HTTPS_PORT=443
DB_PORT=3306

# Database
DB_NAME=wordpress
DB_USER=wpuser
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme
