{# Renders a Gravity Form definition as an async-submit HTML form #}
{% macro renderForm(form, workerUrl) %}
{% set formAction = workerUrl or '#' %}
<form class="gform" data-form-handler="{{ formAction }}" data-form-name="{{ form.title }}">
  <h2>{{ form.title }}</h2>
  {# Honeypot — hidden from real users, catches bots #}
  <div style="position:absolute;left:-9999px" aria-hidden="true">
    <input type="text" name="_honeypot" tabindex="-1" autocomplete="off">
  </div>
  <input type="hidden" name="_formName" value="{{ form.title }}">
  <input type="hidden" name="_formId" value="{{ form.id }}">

  {% for field in form.fields %}
    {% if field.type == 'section' %}
      <hr>
      {% if field.label %}<h3>{{ field.label }}</h3>{% endif %}
    {% elif field.type == 'html' %}
      {# skip HTML fields #}
    {% elif field.type == 'page' %}
      {# skip page breaks #}
    {% else %}
      <div class="gform-field">
        <label for="field_{{ form.id }}_{{ field.id }}">
          {{ field.label }}{% if field.required %} <span class="required">*</span>{% endif %}
        </label>

        {% if field.type == 'textarea' %}
          <textarea id="field_{{ form.id }}_{{ field.id }}" name="{{ field.label | lower | replace(' ', '_') }}"
            {% if field.placeholder %}placeholder="{{ field.placeholder }}"{% endif %}
            {% if field.required %}required{% endif %}></textarea>

        {% elif field.type == 'select' %}
          <select id="field_{{ form.id }}_{{ field.id }}" name="{{ field.label | lower | replace(' ', '_') }}"
            {% if field.required %}required{% endif %}>
            <option value="">{{ field.placeholder or 'Select...' }}</option>
            {% for choice in field.choices %}
              <option value="{{ choice.value }}">{{ choice.text }}</option>
            {% endfor %}
          </select>

        {% elif field.type == 'radio' %}
          {% for choice in field.choices %}
            <label class="radio-label">
              <input type="radio" name="{{ field.label | lower | replace(' ', '_') }}" value="{{ choice.value }}"
                {% if field.required and loop.first %}required{% endif %}>
              {{ choice.text }}
            </label>
          {% endfor %}

        {% elif field.type == 'checkbox' %}
          {% for choice in field.choices %}
            <label class="checkbox-label">
              <input type="checkbox" name="{{ field.label | lower | replace(' ', '_') }}[]" value="{{ choice.value }}">
              {{ choice.text }}
            </label>
          {% endfor %}

        {% elif field.type == 'name' or field.type == 'address' %}
          {% for input in field.inputs %}
            <div class="sub-field">
              <label for="field_{{ form.id }}_{{ input.id }}">{{ input.label }}</label>
              <input type="text" id="field_{{ form.id }}_{{ input.id }}" name="{{ input.label | lower | replace(' ', '_') }}">
            </div>
          {% endfor %}

        {% else %}
          <input type="{{ field.type }}" id="field_{{ form.id }}_{{ field.id }}" name="{{ field.label | lower | replace(' ', '_') }}"
            {% if field.placeholder %}placeholder="{{ field.placeholder }}"{% endif %}
            {% if field.required %}required{% endif %}
            {% if field.maxLength %}maxlength="{{ field.maxLength }}"{% endif %}>
        {% endif %}
      </div>
    {% endif %}
  {% endfor %}
  <button type="submit" class="gform-submit">Submit</button>
  <div class="gform-status" aria-live="polite"></div>
</form>
{% endmacro %}
