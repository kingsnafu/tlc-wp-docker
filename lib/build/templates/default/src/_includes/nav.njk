{% macro renderItems(items) %}
  {% for item in items %}
  <li>
    <a href="{{ item.url }}"{% if item.target %} target="{{ item.target }}"{% endif %}>{{ item.title }}</a>
    {% if item.children.length %}
    <ul>
      {{ renderItems(item.children) }}
    </ul>
    {% endif %}
  </li>
  {% endfor %}
{% endmacro %}

<nav>
  {% for menu in menus %}
  <ul>
    {{ renderItems(menu.items) }}
  </ul>
  {% endfor %}
</nav>
